{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "./src/typescript/index.jsonc",
	"compilerOptions": {
		"incremental": true,
		"lib": ["DOM", "ES2025"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"target": "ESNext",
		"tsBuildInfoFile": "node_modules/.cache/typescript/.tsbuildinfo",
		"types": ["node"]
	}
}
